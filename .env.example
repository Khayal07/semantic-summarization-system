# Environment Configuration
ENV=development

# Model Configuration
MODEL_NAME=facebook/bart-large-cnn
DEVICE=cuda
MAX_LENGTH=1024
MIN_LENGTH=50

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Data Paths
DATASET_PATH=./datasets
MODEL_CACHE_PATH=./model_cache
CHECKPOINT_PATH=./checkpoints
LOG_PATH=./logs

# Experiment Tracking
WANDB_PROJECT=semantic-summarization
WANDB_ENTITY=
WANDB_API_KEY=

# Database (Optional)
DATABASE_URL=

# Logging
LOG_LEVEL=INFO
